<section id="{{ section.settings.anchor | default: 'about' }}" class="about">
  <div class="container about-grid">
    <div>
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      <div>{{ section.settings.body }}</div>
    </div>
    <div class="about-card">
      <div class="about-card-inner">
        <p class="brand-stamp">{{ section.settings.stamp | default: 'RUDRA' }}</p>
        <p class="brand-stamp-sub">{{ section.settings.stamp_sub | default: 'PURE N NATURAL' }}</p>
        <p class="brand-stamp-by">{{ section.settings.stamp_by | default: 'by RVK Ventures' }}</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "About",
  "settings": [
    { "type": "text",     "id": "anchor",    "label": "URL anchor", "default": "about" },
    { "type": "text",     "id": "eyebrow",   "label": "Eyebrow",    "default": "Our Story" },
    { "type": "text",     "id": "heading",   "label": "Heading",    "default": "Fragrance, guided by the stars." },
    { "type": "richtext", "id": "body",      "label": "Body",       "default": "<p>RUDRA was born from a simple belief — that scent is a quiet kind of medicine. For centuries, ittar has been used in India not only as perfume, but as ritual: to calm the mind, lift the spirit, and align the wearer with something larger than themselves.</p><p>We took that tradition and asked a new question. <em>What if a fragrance was made for you — not for the season, not for the trend, but for the energy of your sign?</em></p><p>Each RUDRA ittar is hand-blended in small batches using pure botanical extracts. No alcohol. No synthetic fillers. Just the notes most attuned to your zodiac, distilled into a 12 ml glass bottle.</p>" },
    { "type": "text",     "id": "stamp",     "label": "Stamp",      "default": "RUDRA" },
    { "type": "text",     "id": "stamp_sub", "label": "Stamp sub",  "default": "PURE N NATURAL" },
    { "type": "text",     "id": "stamp_by",  "label": "Stamp by",   "default": "by RVK Ventures" }
  ],
  "presets": [{ "name": "About" }]
}
{% endschema %}
