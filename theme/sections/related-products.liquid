<section class="related">
  <div class="container">
    <header class="section-head">
      <p class="eyebrow">{{ section.settings.eyebrow | default: 'Continue exploring' }}</p>
      <h2>{{ section.settings.heading | default: 'Other zodiacs' }}</h2>
    </header>

    {%- assign coll = collections[section.settings.collection] -%}
    {%- if coll != blank and coll.products.size > 0 -%}
      <div class="zodiac-grid">
        {%- assign shown = 0 -%}
        {%- for p in coll.products -%}
          {%- if p.handle != product.handle and shown < section.settings.products_to_show -%}
            {%- render 'zodiac-card', product: p -%}
            {%- assign shown = shown | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Related products",
  "settings": [
    { "type": "text",       "id": "eyebrow",         "label": "Eyebrow", "default": "Continue exploring" },
    { "type": "text",       "id": "heading",         "label": "Heading", "default": "Other zodiacs" },
    { "type": "collection", "id": "collection",      "label": "Collection to draw from" },
    { "type": "range",      "id": "products_to_show","label": "How many to show", "min": 2, "max": 8, "step": 1, "default": 4 }
  ]
}
{% endschema %}
