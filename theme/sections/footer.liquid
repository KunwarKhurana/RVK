<footer class="site-footer" role="contentinfo">
  <div class="container footer-grid">
    <div>
      <p class="brand-name">{{ section.settings.brand_name | default: 'RUDRA' }}</p>
      <p class="brand-sub">{{ section.settings.brand_tagline | default: 'PURE N NATURAL' }}</p>
      <p class="footer-by">{{ section.settings.brand_by | default: 'by RVK Ventures' }}</p>
    </div>

    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'menu' -%}
          <div {{ block.shopify_attributes }}>
            <p class="footer-head">{{ block.settings.heading }}</p>
            <ul>
              {%- for link in block.settings.menu.links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </div>
        {%- when 'text' -%}
          <div {{ block.shopify_attributes }}>
            <p class="footer-head">{{ block.settings.heading }}</p>
            <p class="footer-fine">{{ block.settings.body }}</p>
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>

  <div class="container footer-bottom">
    <span>© <span id="year"></span> {{ section.settings.legal_name | default: 'RVK Ventures' }}. All rights reserved.</span>
    <span>{{ section.settings.footer_right | default: 'Handcrafted in India' }}</span>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name",
      "default": "RUDRA"
    },
    {
      "type": "text",
      "id": "brand_tagline",
      "label": "Brand tagline",
      "default": "PURE N NATURAL"
    },
    {
      "type": "text",
      "id": "brand_by",
      "label": "Brand attribution",
      "default": "by RVK Ventures"
    },
    {
      "type": "text",
      "id": "legal_name",
      "label": "Legal entity name (for copyright)",
      "default": "RVK Ventures"
    },
    {
      "type": "text",
      "id": "footer_right",
      "label": "Right-hand footer text",
      "default": "Handcrafted in India"
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu",
      "limit": 4,
      "settings": [
        { "type": "text",      "id": "heading", "label": "Heading", "default": "Explore" },
        { "type": "link_list", "id": "menu",    "label": "Menu",    "default": "footer" }
      ]
    },
    {
      "type": "text",
      "name": "Text block",
      "limit": 2,
      "settings": [
        { "type": "text",     "id": "heading", "label": "Heading", "default": "The fine print" },
        { "type": "textarea", "id": "body",    "label": "Body",    "default": "RUDRA ittars are wellness products inspired by traditional astrological practice. They are not intended to diagnose, treat, or cure any medical condition." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "menu", "settings": { "heading": "Explore" } },
        { "type": "menu", "settings": { "heading": "Order" } },
        { "type": "text", "settings": { "heading": "The fine print" } }
      ]
    }
  ]
}
{% endschema %}
