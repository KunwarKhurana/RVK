<section class="collection">
  <div class="container">
    <header class="section-head collection-head">
      <p class="eyebrow">The Collection</p>
      <h1>{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <p class="section-lead">{{ collection.description }}</p>
      {%- endif -%}
      <p class="collection-count">
        {{ 'collections.general.items_with_count' | t: count: collection.products_count }}
      </p>
    </header>

    {%- paginate collection.products by 24 -%}
      {%- if collection.products.size > 0 -%}
        <div class="zodiac-grid">
          {%- for product in collection.products -%}
            {%- render 'zodiac-card', product: product -%}
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <nav class="pagination" style="text-align:center; margin-top:48px; display:flex; gap:12px; justify-content:center;" aria-label="Pagination">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="btn btn-ghost btn-sm">← Previous</a>
            {%- endif -%}
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="btn btn-ghost btn-sm">Next →</a>
            {%- endif -%}
          </nav>
        {%- endif -%}
      {%- else -%}
        <div class="section-head" style="margin-top:60px;">
          <p class="lead" style="margin: 0 auto;">{{ 'collections.general.no_matches' | t }}</p>
        </div>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>
